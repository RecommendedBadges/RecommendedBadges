{
    "env": {
        "es6": true,
        "node": true
    },
    "parserOptions": {
        "ecmaVersion": 13,
        "sourceType": "module"
    },
    "extends": ["@salesforce/eslint-config-lwc/base"],
    "overrides": [
      {
        "files": ["*.test.js"],
        "rules": {
          "@lwc/lwc/no-unexpected-wire-adapter-usages": "off",
          "@lwc/lwc-platform/no-aura-libs": "off",
          "@lwc/lwc-platform/no-process-env": "off"
        }
      },
      {
        "files": ["node-scripts/**/*.js"],
        "extends": ["eslint:recommended"],
        "env": {
          "node": true,
          "es6": true
        },
        "parserOptions": {
          "ecmaVersion": 2022,
          "sourceType": "module"
        },
        "rules": {
          "@lwc/lwc-platform/no-aura-libs": "off",
          "@lwc/lwc-platform/no-process-env": "off"
        }
      }
    ]
  }
  